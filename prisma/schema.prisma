datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id              String   @id @default(cuid())
  seqId           Int      @default(autoincrement())
  username        String   @unique
  walletAddress   String   @unique
  referredByUser  User?    @relation("Referrals", fields: [referredById], references: [id])
  referredById    String?
  referrals       User[]   @relation("Referrals")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stakes              Stake[]
  withdrawals         Withdrawal[]
  referralEarnings    ReferralEarning[]
  userCredit          UserCredit?
  userBalance         UserBalance?
  deposits            Deposit[]
  virtualStakes       VirtualStake[]
  virtualWithdrawals  VirtualWithdrawal[]
}

model Stake {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        String
  stakeStartTime DateTime
  unlockTime    DateTime
  lastClaimTime DateTime
  isActive      Boolean  @default(true)
  txHash        String?
  createdAt     DateTime @default(now())
}

model Withdrawal {
  id           String   @id @default(cuid())
  contractId   Int
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  amount       String
  assetType    Int      // 0=AZR 1=USDT
  status       Int      @default(0) // 0=PENDING 1=APPROVED 2=REJECTED
  txHash       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReferralEarning {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fromUser   String
  level      Int
  amount     String
  txHash     String?
  createdAt  DateTime @default(now())
}

model UserCredit {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
}

model UserBalance {
  id          Int      @id @default(autoincrement())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  usdtBalance Float    @default(0)
  azrBalance  Float    @default(0)
  updatedAt   DateTime @updatedAt
}

model Deposit {
  id          Int       @id @default(autoincrement())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  txHash      String    @unique
  amount      Float
  status      Int       @default(1) // 1=confirmed, 2=rejected
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([userId])
}

model VirtualStake {
  id            Int      @id @default(autoincrement())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  startTime     DateTime @default(now())
  lastClaimTime DateTime @default(now())
  unlockTime    DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model VirtualWithdrawal {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Float
  assetType  Int      // 0=AZR, 1=USDT
  toWallet   String
  status     Int      @default(0) // 0=pending, 1=sent, 2=rejected
  sentTxHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model ClaimHistory {
  id        Int      @id @default(autoincrement())
  wallet    String
  stakeId   Int
  amount    String
  txHash    String
  claimedAt DateTime @default(now())

  @@unique([txHash, stakeId])
  @@index([wallet])
}
